# ─── HalfTime Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Stripe (client-side publishable key only) ─────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# ── Stripe (server-side — Supabase Edge Functions only) ──────────────────────
# Set these as Supabase secrets, NOT as VITE_ vars (they must not reach the browser):
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#
# STRIPE_SECRET_KEY=sk_test_your-secret-key-here      ← DO NOT put in .env
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret     ← DO NOT put in .env

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
# The PUBLIC key goes here (safe for browser). Set private key as a Supabase secret:
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:you@yourdomain.com
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── Optional: Persona KYC (Week 3) ───────────────────────────────────────────
# VITE_PERSONA_TEMPLATE_ID=itmpl_your-template-id
